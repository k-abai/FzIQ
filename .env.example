# FzIQ Environment Variables — copy to .env and fill in your values

# Model
BASE_MODEL_PATH=microsoft/Phi-3-mini-4k-instruct
FINETUNED_MODEL_PATH=./metamodel/checkpoints/latest
DEVICE=cuda

# opBNB
OPBNB_RPC_URL=https://opbnb-testnet-rpc.bnbchain.org
AGGREGATOR_PRIVATE_KEY=your_private_key_here
CONTRACT_ADDRESS=deployed_contract_address_here

# Aggregation
AGGREGATION_INTERVAL_HOURS=24
MIN_GRADIENTS_PER_ROUND=5

# Grading
HUMAN_GRADER_PORT=5000
CNN_CONFIDENCE_THRESHOLD=0.7
HUMAN_WEIGHT=0.6
CNN_WEIGHT=0.4

# Wandb (experiment tracking)
WANDB_PROJECT=fziq
WANDB_ENTITY=your_wandb_username

# Database
GRADES_DB_PATH=./data/grades.db
